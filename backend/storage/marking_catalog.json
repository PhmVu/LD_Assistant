{
  "catalog_version": "0.1.0",
  "name": "LD Road Marking Catalog",
  "purpose": "Starter catalog for AI LD and drawing_engine. It maps road-marking codes to visual presets, image asset slots, and renderer kinds.",
  "status": "seed_from_current_tool_and_reference_images",
  "notes": [
    "Exact legal wording and dimensions should be locked from the official LD/QCVN documents in backend storage before production use.",
    "The image paths are reserved slots for thumbnails/reference previews. The PNG/SVG assets are not embedded in this JSON.",
    "drawing_engine_status=supported means the current drawing_engine can already render a close visual family. to_add means a new preset should be added.",
    "For road_edge contexts, image/line4d_image is the shared red 4D drawing. attribute_image is used only when the user explicitly mentions the edge attribute."
  ],
  "image_asset_root": "backend/storage/marking_images",
  "frontend_asset_root": "frontend/public/markings",
